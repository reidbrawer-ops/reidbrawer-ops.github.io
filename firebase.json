{
  "firestore": {
    "rules": "firestore.rules"
  },
  "hosting": {
    "public": ".",
    "cleanUrls": true,
    "predeploy": [
      "node scripts/validate.mjs",
      "node scripts/check-redesign-invariants.mjs",
      "node scripts/hash-modules.mjs --check"
    ],
    "redirects": [
      {
        "source": "/gear",
        "destination": "/paddles",
        "type": 301
      },
      {
        "source": "/paddle-quiz",
        "destination": "/paddles",
        "type": 301
      },
      {
        "source": "/directory",
        "destination": "/map",
        "type": 301
      }
    ],
    "headers": [
      {
        "source": "**",
        "headers": [
          {
            "key": "Cache-Control",
            "value": "public, max-age=300, must-revalidate"
          }
        ]
      },
      {
        "source": "**/*.@(css|json)",
        "headers": [
          {
            "key": "Cache-Control",
            "value": "public, max-age=600, must-revalidate"
          }
        ]
      },
      {
        "source": "**/*.js",
        "headers": [
          {
            "key": "Cache-Control",
            "value": "public, no-cache"
          }
        ]
      },
      {
        "source": "/assets/m/**",
        "headers": [
          {
            "key": "Cache-Control",
            "value": "public, max-age=31536000, immutable"
          }
        ]
      },
      {
        "source": "**/*.@(png|jpg|jpeg|gif|svg|webp|ico|woff|woff2)",
        "headers": [
          {
            "key": "Cache-Control",
            "value": "public, max-age=604800"
          }
        ]
      },
      {
        "source": "/@(favicon.ico|favicon.svg|apple-touch-icon.png|site.webmanifest)",
        "headers": [
          {
            "key": "Cache-Control",
            "value": "public, max-age=0, must-revalidate"
          }
        ]
      },
      {
        "source": "/assets/logo/**",
        "headers": [
          {
            "key": "Cache-Control",
            "value": "public, max-age=0, must-revalidate"
          }
        ]
      }
    ],
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**",
      "scripts/**",
      "partials/**",
      "pickleheads-research/**",
      "audit/**",
      "quiz/**",
      "design_handoff_pickleball_redesign/**",
      "design_handoff_paddle_comparison/**",
      "design_handoff_favicon/**",
      "design_handoff_paddle_finder/**",
      "design_handoff_head_to_head_swap/**",
      "_pc-test.html",
      "**/*.md",
      "firestore.rules",
      "**/*.log"
    ]
  }
}
